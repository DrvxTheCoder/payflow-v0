    "hooks": "@/hooks"
  },
  "registries": {
    "@bklit": "https://ui.bklit.com/r/{name}.json",
    "@animate-ui": "https://animate-ui.com/r/{name}.json",
    "@eldoraui": "https://eldoraui.site/r/{name}.json",
    "@unlumen-ui": "https://ui.unlumen.com/r/{name}.json"
  }
}
